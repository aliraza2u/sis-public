// ─── Student Grades (manual + import, transcript) ───────────────────────────

enum GradeSource {
  manual
  import
}

enum GradeResult {
  pass
  fail
}

model StudentCourseGrade {
  id       String @id @default(dbgenerated("generate_prefixed_uuid('GRD')")) @db.VarChar(50)
  tenantId String @map("tenant_id") @db.VarChar(50)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.VarChar(50)
  courseId String @map("course_id") @db.VarChar(50)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  applicationId String? @map("application_id") @db.VarChar(50)

  source     GradeSource @default(manual)
  finalResult GradeResult @map("final_result")
  finalGrade  String?    @map("final_grade") @db.VarChar(10)  // e.g. A, B+
  finalScore  Decimal?   @map("final_score") @db.Decimal(5, 2) // e.g. 85.00
  breakdown   Json?      @default("[]") // [{ type, name, score, maxScore }]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, userId, courseId])
  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
  @@map("student_course_grades")
}

model Transcript {
  id       String @id @default(dbgenerated("generate_prefixed_uuid('TRN')")) @db.VarChar(50)
  tenantId String @map("tenant_id") @db.VarChar(50)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.VarChar(50)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transcriptNumber  String  @unique @map("transcript_number") @db.VarChar(100)
  verificationToken String  @unique @map("verification_token") @db.VarChar(500)

  issuedAt DateTime @default(now()) @map("issued_at") @db.Timestamptz
  isActive  Boolean  @default(true) @map("is_active")
  isRevoked Boolean  @default(false) @map("is_revoked")
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  revokedBy String?   @map("revoked_by") @db.VarChar(50)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([transcriptNumber])
  @@index([verificationToken])
  @@map("transcripts")
}

// ─── Data Transfer ──────────────────────────────────────────────────────────

enum ImportJobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

model ImportJob {
  id       String @id @default(dbgenerated("generate_prefixed_uuid('IMP')")) @db.VarChar(50)
  tenantId String @map("tenant_id") @db.VarChar(50)
  userId   String @map("user_id") @db.VarChar(50)

  entityType String          @map("entity_type") @db.VarChar(50)
  status     ImportJobStatus @default(pending)

  totalRows     Int @default(0) @map("total_rows")
  processedRows Int @default(0) @map("processed_rows")
  successCount  Int @default(0) @map("success_count")
  errorCount    Int @default(0) @map("error_count")

  progress Float @default(0.0)

  sourceFilePath String? @map("source_file_path") @db.Text
  failedRowsPath String? @map("failed_rows_path") @db.Text
  errorDetails   Json?   @map("error_details")

  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId])
  @@index([userId])
  @@map("import_jobs")
}
