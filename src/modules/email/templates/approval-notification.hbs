<html dir='{{dir}}'>
  <head>
    <meta charset='utf-8' />
    <title>{{subject}}</title>
  </head>
  <body style='font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; direction: {{dir}}; text-align: {{align}};'>
    <div style='background-color: #f8f9fa; padding: 30px; border-radius: 8px;'>
      <!-- Header -->
      <div style='text-align: center; margin-bottom: 30px;'>
        <h1 style='color: #10b981; margin-bottom: 10px;'>{{header}}</h1>
        <h2 style='color: #2c3e50; margin-top: 0;'>{{subHeader}}</h2>
      </div>

      <!-- Main Content -->
      <div style='background-color: white; padding: 25px; border-radius: 6px; margin-bottom: 20px;'>
        <p style='color: #34495e; font-size: 16px; line-height: 1.6;'>
          {{greeting}}
        </p>
        <p style='color: #34495e; font-size: 16px; line-height: 1.6;'>
          {{approvalBody}}
        </p>

        <!-- Application Details -->
        <div style='background-color: #f8f9fa; padding: 20px; border-radius: 4px; margin: 20px 0;'>
          <h3 style='color: #2c3e50; margin-top: 0; font-size: 18px;'>{{detailsHeader}}</h3>
          <table style='width: 100%; border-collapse: collapse; text-align: {{align}};'>
            <tr>
              <td style='padding: 8px 0; color: #7f8c8d; font-weight: bold;'>{{studentIdLabel}}</td>
              <td style='padding: 8px 0; color: #2c3e50;'>{{rollNumber}}</td>
            </tr>
            <tr>
              <td style='padding: 8px 0; color: #7f8c8d; font-weight: bold;'>{{courseLabel}}</td>
              <td style='padding: 8px 0; color: #2c3e50;'>{{courseName}}</td>
            </tr>
            <tr>
              <td style='padding: 8px 0; color: #7f8c8d; font-weight: bold;'>{{batchLabel}}</td>
              <td style='padding: 8px 0; color: #2c3e50;'>{{batchName}}</td>
            </tr>
            <tr>
              <td style='padding: 8px 0; color: #7f8c8d; font-weight: bold;'>{{startDateLabel}}</td>
              <td style='padding: 8px 0; color: #2c3e50;'>{{batchStartDate}}</td>
            </tr>
          </table>
        </div>

        <!-- Next Steps -->
        <div style='margin: 25px 0;'>
          <h3 style='color: #2c3e50; font-size: 18px;'>{{nextStepsHeader}}</h3>
          <ol style='color: #34495e; line-height: 1.8;'>
            <li>{{nextStep1}}</li>
            <li>{{nextStep2}}</li>
            <li>{{nextStep3}}</li>
          </ol>
        </div>

        {{#if lmsUrl}}
          <!-- LMS Access Button -->
          <div style='text-align: center; margin: 30px 0;'>
            <a
              href='{{lmsUrl}}'
              style='background-color: #4F46E5; color: white; padding: 14px 28px; text-decoration: none; border-radius: 6px; font-weight: bold; display: inline-block; font-size: 16px;'
            >{{accessLmsButton}}</a>
          </div>
        {{/if}}

        <p style='color: #34495e; font-size: 16px; line-height: 1.6;'>
          {{seeYouOn}}
        </p>
      </div>

      <!-- Footer -->
      <p
        style='color: #95a5a6; font-size: 13px; text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #e1e1e1;'
      >
        {{footerAutomated}}<br />
        {{footerSupport}}
      </p>
    </div>
  </body>
</html>