<html>
  <head>
    <meta charset='utf-8' />
    <title>Reset your password</title>
  </head>
  <body style='font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;'>
    <div
      style='background-color: #f8fafc; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0;'
    >
      <h2 style='color: #1e293b; text-align: center;'>
        {{#if isSetup}}Setup Your SIS Account{{else}}Reset Password Request{{/if}}
      </h2>
      <p style='color: #334155; font-size: 16px; line-height: 1.6;'>
        {{#if isSetup}}
          Welcome to the Student Information System! Please click the button below to set up your
          password and access your account.
        {{else}}
          You requested to reset your password. Click the button below to proceed:
        {{/if}}
      </p>
      <div style='text-align: center; margin: 30px 0;'>
        <a
          href='{{resetUrl}}'
          style='background-color: #2563eb; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px; font-weight: bold; display: inline-block;'
        >
          {{#if isSetup}}Setup Password{{else}}Reset Password{{/if}}
        </a>
      </div>
      <p style='color: #64748b; font-size: 14px;'>
        Or use this token:
        <strong>{{token}}</strong>
      </p>
      <p
        style='color: #94a3b8; font-size: 12px; margin-top: 30px; text-align: center; border-top: 1px solid #e2e8f0; padding-top: 20px;'
      >
        {{#if isSetup}}
          If you were not expecting this invitation, please ignore this email.
        {{else}}
          If you didn't request this, please ignore this email. Your password will remain unchanged.
        {{/if}}
      </p>
    </div>
  </body>
</html>