# App
NODE_ENV=development
APP_PORT=3001
APP_PREFIX=api
APP_NAME="Student Information System"

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sis_db
DB_PORT=5434
# Updated to point to localhost DB served by docker-compose for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/sis_db?schema=public"

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE="Student Information System API"
SWAGGER_DESCRIPTION="API Documentation for Student Information System"
SWAGGER_VERSION="1.0"
SWAGGER_PATH="api/docs"