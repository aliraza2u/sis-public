# App
NODE_ENV=development
APP_PORT=3000
APP_PREFIX=api
APP_NAME="Student Information System"

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sis_db
DB_PORT=5434
# Updated to point to localhost DB served by docker-compose for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/sis_db?schema=public"

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE="SIS API"
SWAGGER_DESCRIPTION="API Documentation for Student Information System"
SWAGGER_VERSION="1.0"
SWAGGER_PATH="api/docs"
# SendGrid Configuration
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=your-email@example.com

# Frontend
FRONTEND_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET="super-secret-key-change-in-prod"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="super-refresh-secret-change-in-prod"
JWT_REFRESH_EXPIRES_IN="7d"

# Admin User Creation (Optional - for scripts/create-admin.ts)
# Leave empty to use interactive prompts during development
# Set in production/CI for automated admin creation
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=SecurePassword123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator
DEFAULT_TENANT_SLUG=al-mkki

# Auth Configuration
AUTH_EMAIL_VERIFICATION_EXPIRY=24
AUTH_PASSWORD_RESET_EXPIRY=1
AUTH_REFRESH_TOKEN_EXPIRY_DAYS=7

# Hashing
APP_SALT_ROUNDS=12

# Data Transfer (Import/Export)
DATA_TRANSFER_MAX_FILE_SIZE=10485760 # 10MB in bytes
DATA_TRANSFER_BATCH_SIZE=50  # Number of rows to process at once
DATA_TRANSFER_TEMP_FILE_MAX_AGE=86400000  # 24 hours in milliseconds
